#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Venv discovery — prefer skill's own venv (has pdfplumber)
PYTHON=""
for candidate in \
    "${MORNING_CHECK_PYTHON:-}" \
    "$SCRIPT_DIR/.venv/bin/python3" \
    "$HOME/code/playground/stock-price-analyze/venv312/bin/python3" \
    "$HOME/code/playground/stock-price-analyze/.venv/bin/python3" \
    "$HOME/code/playground/stock-price-analyze/venv/bin/python3"; do
    if [ -n "$candidate" ] && [ -x "$candidate" ] 2>/dev/null; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    PYTHON="$(command -v python3 || true)"
fi

if [ -z "$PYTHON" ]; then
  echo "ERROR: No Python interpreter found" >&2
  exit 1
fi

exec "$PYTHON" "$SCRIPT_DIR/fetch_stock_info.py" "$@"
