#!/usr/bin/env bash
# Wrapper that runs fetch_portfolio.py with the correct Python venv.
# Discovery order: MORNING_CHECK_PYTHON env → TradingAgents venv →
# stock-price-analyze venvs → system python3

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

_discover_python() {
    if [[ -n "${MORNING_CHECK_PYTHON:-}" ]] && [[ -x "$MORNING_CHECK_PYTHON" ]]; then
        echo "$MORNING_CHECK_PYTHON"
        return
    fi

    local candidates=(
        "$HOME/code/deepcode/TradingAgents/.venv/bin/python3"
        "$HOME/code/playground/stock-price-analyze/.venv/bin/python3"
        "$HOME/code/playground/stock-price-analyze/venv312/bin/python3"
        "$HOME/code/playground/stock-price-analyze/venv/bin/python3"
    )

    for py in "${candidates[@]}"; do
        if [[ -x "$py" ]]; then
            echo "$py"
            return
        fi
    done

    echo "python3"
}

PYTHON=$(_discover_python)
exec "$PYTHON" "$SCRIPT_DIR/fetch_portfolio.py" "$@"
